# ==========================================
# ZQCMS 环境变量配置
# 复制此文件为 .env 并填写实际值
# ==========================================

# MySQL root 密码（用于初始化数据库）
# 如果不设置，setup-db.sh 会尝试无密码连接
MYSQL_ROOT_PASSWORD=

# 后端 API 端口
API_PORT=11003

# JWT 密钥（生产环境请更换为随机字符串）
JWT_SECRET=zqcms-jwt-secret-change-in-production-2024

# 数据库连接（Prisma 使用）
DATABASE_URL=mysql://zqcms:zqcms_pass_2024@localhost:3306/zqcms
