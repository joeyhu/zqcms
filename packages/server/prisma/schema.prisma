generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 站点（替代旧 SiteSettings，支持多站点）
// ==========================================
model Site {
  id            Int      @id @default(autoincrement())
  name          String // 站点名称
  slug          String   @unique // 内部标识（?site=slug 用）
  domain        String   @unique // 绑定域名
  isDefault     Boolean  @default(false) // 默认站点（dev 兜底）
  description   String?  @db.Text // 站点描述
  logo          String? // Logo URL
  favicon       String? // Favicon URL
  primaryColor  String   @default("#3B82F6") // 主题色
  contactEmail  String? // 联系邮箱
  contactPhone  String? // 联系电话
  address       String? // 地址
  socialLinks   Json? // { github: "...", twitter: "..." }
  socialQRCodes Json? // { "微信公众号": "/uploads/1/qr.png", "抖音": "/uploads/1/dy.png" }
  footerText    String?  @db.Text // 页脚文案
  copyright     String? // 版权信息
  gaId          String? // Google Analytics ID
  icp           String? // ICP 备案号（如 京ICP备2024000001号）
  isActive      Boolean  @default(true) // 是否启用
  createdAt     DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  categories    Category[]
  posts         Post[]
  media         Media[]
  feedback      Feedback[]

  @@index([domain])
  @@index([slug])
}

// ==========================================
// 多级导航目录（加 siteId）
// ==========================================
model Category {
  id          Int        @id @default(autoincrement())
  siteId      Int // 所属站点
  site        Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?    @db.Text
  icon        String?
  url         String? // 外部链接，设置后导航点击在新 tab 打开，不展示目录页
  sortOrder   Int        @default(0)
  isVisible   Boolean    @default(true)
  parentId    Int?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  posts       Post[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([siteId, slug])
  @@index([siteId, sortOrder])
  @@index([siteId, parentId])
}

// ==========================================
// 文章（加 siteId）
// ==========================================
model Post {
  id         Int        @id @default(autoincrement())
  siteId     Int // 所属站点
  site       Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title      String
  slug       String
  content    String     @db.LongText
  excerpt    String?    @db.Text
  coverImage String?
  status     PostStatus @default(DRAFT)
  sortOrder  Int        @default(0)
  categoryId Int?
  category   Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId   String?
  author     User?      @relation(fields: [authorId], references: [id])
  tags       PostTag[]

  seoTitle String?
  seoDesc  String? @db.Text

  viewCount   Int       @default(0)
  isPinned    Boolean   @default(false)
  isFeatured  Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([siteId, categoryId, slug])
  @@index([siteId, sortOrder])
  @@index([siteId, categoryId, status, sortOrder])
  @@index([slug, status])
  @@fulltext([title])
  @@fulltext([content])
  @@fulltext([excerpt])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ==========================================
// 用户（全局管理员，不变）
// ==========================================
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String?
  role        Role     @default(EDITOR)
  isActive    Boolean  @default(true)
  permissions Json?    // 菜单权限: ["posts", "categories", "tags", "media", "settings", "sites", "users"]
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

enum Role {
  ADMIN
  EDITOR
}

// ==========================================
// 标签（全局共享，不变）
// ==========================================
model Tag {
  id    Int       @id @default(autoincrement())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]
}

model PostTag {
  postId Int
  tagId  Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

// ==========================================
// 媒体文件（加 siteId）
// ==========================================
model Media {
  id        Int      @id @default(autoincrement())
  siteId    Int // 所属站点
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  filename  String
  url       String
  mimeType  String
  size      Int
  altText   String?
  createdAt DateTime @default(now())

  @@index([siteId])
}

// ==========================================
// LLM 配置（AI 助手）
// ==========================================
model LlmConfig {
  id        Int      @id @default(autoincrement())
  name      String   // 配置名称，如 "DeepSeek V3"
  provider  String   // 提供商标识: openai / deepseek / qwen / custom
  apiKey    String   // API Key
  baseUrl   String   // API 端点地址
  model     String   // 模型名称，如 deepseek-chat, qwen-max
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 内容发布平台（微信公众号等）
// ==========================================
model PublishPlatform {
  id          Int      @id @default(autoincrement())
  name        String   // 账号名称，如 "ZQCMS官方公众号"
  platform    String   // 平台类型: wechat
  appId       String   // AppID
  appSecret   String   // AppSecret
  qrcode      String?  // 二维码图片URL
  description String?  // 备注说明
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records PublishRecord[]
}

// ==========================================
// 发布记录
// ==========================================
model PublishRecord {
  id         Int             @id @default(autoincrement())
  postId     Int             // 关联文章ID
  platformId Int             // 关联平台账号ID
  platform   PublishPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  status     String          @default("pending") // pending | submitted | success | failed
  publishId  String?         // 平台返回的发布ID
  errorMsg   String?         // 失败原因
  createdAt  DateTime        @default(now())

  @@index([postId])
  @@index([platformId])
}

// ==========================================
// 用户反馈建议
// ==========================================
model Feedback {
  id        Int      @id @default(autoincrement())
  siteId    Int
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String               // 用户姓名
  phone     String?              // 联系电话
  email     String?              // 联系邮箱
  content   String   @db.Text    // 反馈内容
  pageUrl   String?              // 提交反馈时的页面 URL
  status    String   @default("pending") // pending | reviewed | resolved | closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId])
  @@index([status])
  @@index([createdAt])
}
