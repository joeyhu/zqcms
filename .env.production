# ==========================================
# ZQCMS Docker 生产环境变量
# 复制此文件为 .env.production 并修改实际值
# ==========================================

# ── 数据库 ──
MYSQL_ROOT_PASSWORD=zqcms_root_2024
MYSQL_PASSWORD=zqcms_pass_2024

# ── JWT 密钥（生产环境必须更换为随机字符串） ──
JWT_SECRET=zqcms-jwt-secret-change-in-production-2024

# ── 站点 URL（用于 sitemap / OG / canonical） ──
SITE_URL=https://your-domain.com

# ── Revalidate API Token（可选，用于后端触发前端缓存刷新） ──
REVALIDATE_TOKEN=
